{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schemaVersion", "skillGroups"],
  "properties": {
    "schemaVersion": {"type": "string"},
    "skillGroups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "description", "topicIds", "syllabusPointIds", "atomicSkillIds", "origin", "review"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
          "label": {"type": "string", "minLength": 3},
          "description": {"type": "string", "minLength": 30},
          "topicIds": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "syllabusPointIds": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "atomicSkillIds": {"type": "array", "minItems": 2, "items": {"type": "string"}},
          "origin": {"const": "lattice-derived"},
          "review": {"type": "object"}
        }
      }
    }
  }
}
