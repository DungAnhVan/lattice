{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lattice://schemas/0580/syllabus-point.schema.json",
  "title": "Lattice Syllabus Point Collection",
  "type": "object",
  "required": ["schemaVersion", "syllabusPoints"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "syllabusPoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "syllabusCode",
          "tier",
          "topicId",
          "officialCode",
          "officialTitle",
          "officialStatement",
          "notes",
          "examplesFromSyllabus",
          "atomicSkillIds",
          "prerequisiteSyllabusPointIds",
          "relatedSyllabusPointIds",
          "origin",
          "sourceReferences",
          "extraction",
          "review"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[CE][1-9]\\.[0-9]+$" },
          "syllabusCode": { "type": "string" },
          "tier": { "enum": ["core", "extended"] },
          "topicId": { "type": "string" },
          "officialCode": { "type": "string" },
          "officialTitle": { "type": "string" },
          "officialStatement": { "type": "string", "minLength": 1 },
          "notes": { "type": "array", "items": { "type": "string" } },
          "examplesFromSyllabus": { "type": "array", "items": { "type": "string" } },
          "atomicSkillIds": { "type": "array", "items": { "type": "string" } },
          "prerequisiteSyllabusPointIds": { "type": "array", "items": { "type": "string" } },
          "relatedSyllabusPointIds": { "type": "array", "items": { "type": "string" } },
          "extendedOnlyPlaceholder": { "type": "boolean" },
          "origin": { "const": "official-syllabus" },
          "sourceReferences": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["page", "section"],
              "properties": {
                "page": { "type": "integer", "minimum": 1 },
                "section": { "type": "string" },
                "tableRow": { "type": "string" }
              }
            }
          },
          "extraction": {
            "type": "object",
            "required": ["status", "confidence", "rawSourceId", "issues"],
            "properties": {
              "status": { "enum": ["clean", "needs-review", "failed"] },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "rawSourceId": { "type": "string" },
              "issues": { "type": "array", "items": { "type": "string" } }
              ,"method": { "type": "string" },
              "verifiedBy": { "type": ["string", "null"] },
              "verifiedAt": { "type": ["string", "null"] }
            }
          },
          "review": {
            "type": "object",
            "required": ["status", "notes"],
            "properties": {
              "status": { "enum": ["pending-review", "approved", "rejected", "needs-revision"] },
              "notes": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
