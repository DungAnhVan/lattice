{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lattice://schemas/0580/relationships.schema.json",
  "title": "Lattice Taxonomy Relationships",
  "type": "object",
  "required": ["schemaVersion", "relationships"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "from", "to", "origin"],
        "properties": {
          "type": {
            "enum": [
              "topic-contains-syllabus-point",
              "syllabus-point-requires-atomic-skill",
              "syllabus-point-prerequisite-of",
              "syllabus-point-related-to",
              "atomic-skill-prerequisite-of",
              "atomic-skill-related-to",
              "core-point-extended-by"
            ]
          },
          "from": { "type": "string" },
          "to": { "type": "string" },
          "origin": { "enum": ["official-syllabus", "lattice-derived"] },
          "equivalence": { "type": "string" }
        }
      }
    }
  }
}
